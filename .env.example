# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
# Local dev: DB_HOST=localhost  |  Docker compose: DB_HOST=mysql  |  Prod: your RDS endpoint
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=university_events
# Auto-create/update tables from entities. Keep true for this exercise; use migrations in prod.
DB_SYNCHRONIZE=true

# AWS S3 (image storage)
AWS_REGION=us-east-1
S3_BUCKET=my-university-events-bucket
# Optional: leave blank on ECS/EC2 to use the instance IAM role instead of static keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
